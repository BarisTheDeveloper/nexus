{
  "name": "@baristhedeveloper/nexus",
  "version": "0.4.0",
  "description": "Multi-LLM Orchestrated CLI — multi-model, role-based AI panel with persistent memory, MCP & skill support",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "nexus": "dist/cli/index.js",
    "nexus-update": "dist/cli/nexus-update.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.tsx",
    "dev:watch": "tsx watch src/cli/index.tsx",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "cli",
    "multi-agent",
    "orchestrator",
    "terminal",
    "mcp",
    "coding-agent"
  ],
  "author": "BarisTheDeveloper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BarisTheDeveloper/nexus.git"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "meow": "^13.0.0",
    "openai": "^4.67.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "ollama": "^0.5.0",
    "better-sqlite3": "^11.0.0",
    "execa": "^9.0.0",
    "yaml": "^2.6.0",
    "chalk": "^5.3.0",
    "conf": "^13.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
